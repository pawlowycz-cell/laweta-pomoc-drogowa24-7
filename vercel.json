{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "laweta-warszawa.net" }],
      "destination": "https://www.laweta-warszawa.net/:path*",
      "permanent": true
    }
  ]
}
